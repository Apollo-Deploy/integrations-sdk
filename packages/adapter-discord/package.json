{
  "name": "@apollo-deploy/adapter-discord",
  "version": "1.0.0",
  "description": "Discord adapter for Apollo Deploy integration hub",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
